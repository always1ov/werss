# =====================================================================
#  WeRSS 极简部署环境变量（配合 docker-compose.simple.yml 使用）
#  复制此文件后修改：cp .env.simple.example .env.simple
# =====================================================================

# 数据库（默认 SQLite，数据保存在 ./data/db.db）
DB=sqlite:///data/db.db

# 管理员账号（强烈建议修改密码）
WERSS_USERNAME=admin
WERSS_PASSWORD=admin@123

# 是否启用定时采集任务
ENABLE_JOB=True

# 是否抓取文章正文（合规需确认有权使用后再开启）
GATHER_CONTENT=True

# 采集间隔（秒），默认 60 分钟
SPAN_INTERVAL=3600

# 时区
TZ=Asia/Shanghai
